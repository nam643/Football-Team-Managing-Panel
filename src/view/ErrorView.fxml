<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>


<?import java.net.URL?>
<?import javafx.scene.control.Separator?>
<VBox alignment="CENTER" styleClass="background" prefWidth="540.0" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ErrorController" spacing="10">
    <ImageView fitWidth="540" fitHeight="300">
        <Image url="@image/error.png"/>
    </ImageView>
    <Separator/>
    <Label styleClass="error" fx:id="errorTypeLbl"/>
    <Separator/>
    <Label fx:id="messageLbl" styleClass="heading"/>
    <Button text="Close" styleClass="button" prefWidth="540" onAction="#handleClose"/>
    <stylesheets>
        <URL value="@style.css"/>
    </stylesheets>
</VBox>